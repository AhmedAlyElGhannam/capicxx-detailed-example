{
    "unicast": "127.0.0.1",
    "logging": {
        "level": "debug",
        "console": "true",
        "file": {
            "enable": "true",
            "path": "/var/log/vsomeip.log"
        },
        "dlt": "false"
    },
    "applications": [
        {
            "name": "IVI-Client",
            "id": "0x127A"
        }
    ],
    "routing": "IVI-Client",
    "service-discovery": {
        "enable": true,
        "protocol": "udp",
        "multicast": "224.224.224.245",
        "port": 30490,
        "initial_delay_min": 10,
        "initial_delay_max": 100,
        "repetitions_base_delay": 200,
        "repetitions_max": 3,
        "ttl": 3,
        "cyclic_offer_delay": 2000,
        "request_response_delay": 1500,
        "offer_debounce": 1000
    }
}
